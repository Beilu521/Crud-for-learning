<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.beilu.demo.mapper.UserMapper">
    
    <resultMap id="UserResultMap" type="com.beilu.demo.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="nickname" property="nickname"/>
        <result column="age" property="age"/>
        <result column="email" property="email"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

   
    <select id="selectByUsername" resultMap="UserResultMap">
        SELECT id, username, nickname, age, email, create_time, update_time
        FROM user
        WHERE username LIKE CONCAT('%', #{username}, '%')
    </select>

    
    <select id="selectByNickname" resultMap="UserResultMap">
        SELECT id, username, nickname, age, email, create_time, update_time
        FROM user
        WHERE nickname LIKE CONCAT('%', #{nickname}, '%')
    </select>
</mapper>